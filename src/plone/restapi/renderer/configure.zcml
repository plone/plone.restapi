<configure
    xmlns="http://namespaces.zope.org/zope"
    i18n_domain="plone.restapi"
    >

  <!-- JSON Renderer -->
  <adapter
      factory=".json.JSONRenderer"
      provides="..interfaces.IRenderer"
      name="application/json"
      />

  <!-- Markdown Renderer -->
  <adapter
      factory=".markdown.MarkdownRenderer"
      provides="..interfaces.IRenderer"
      name="text/markdown"
      />

</configure>
